# scripts/app-auth/.env.app-auth.example
#
# Copy to scripts/app-auth/.env.app-auth and fill the values BY HAND.
# This file is the template — never put real secrets here.
#
# The apply / check scripts in scripts/app-auth/ load scripts/app-auth/.env.app-auth
# (NOT the repo-root .env). Keeping it scoped here prevents accidental cross-use
# with the BFF runtime or the cutover scripts.

# YANDEX_DATABASE_URL — full DSN to Yandex Managed PostgreSQL.
# Format:
#   postgresql://USER:PASSWORD@HOST:6432/HubTender?sslmode=verify-full&sslrootcert=.certs/yandex-root.crt
# Required by both 00_check_app_auth_schema.mjs and 01_apply_app_auth_schema.mjs.
YANDEX_DATABASE_URL=

# ALLOW_APPLY_APP_AUTH_SCHEMA — hard safety gate for real apply.
# Must be the literal string "true" to actually execute the apply against the DB.
# Anything else (false / empty / unset) refuses to run real apply.
# --dry-run does NOT require this flag.
ALLOW_APPLY_APP_AUTH_SCHEMA=false
