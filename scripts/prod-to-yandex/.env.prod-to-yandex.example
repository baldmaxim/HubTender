# scripts/prod-to-yandex/.env.prod-to-yandex.example
#
# Copy to scripts/prod-to-yandex/.env.prod-to-yandex and fill from
# Lockbox / Vault / secret manager. The real file is git-ignored — NEVER commit
# DSNs, passwords, or certificates.
#
# Source of truth for the Yandex stage = PROD Supabase ONLY.
# OLD_SUPABASE_DB_URL is intentionally absent and MUST NOT be added here.

# PROD Supabase (ocauafggjrqvopxjihas) — the ONLY valid migration source.
PROD_SUPABASE_DB_URL=

# Yandex Managed PostgreSQL — migration target (main endpoint; may be pooler).
YANDEX_DATABASE_URL=

# Yandex direct / session-safe endpoint (needed for LISTEN/NOTIFY at runtime
# cutover; transaction-pooler breaks `rowchange`). Optional for schema build.
YANDEX_DIRECT_DATABASE_URL=

# Path to the Yandex root CA (.pem) for sslmode=verify-full. If empty, the
# scripts fall back to the sslrootcert= query param inside the DSN.
YANDEX_SSL_ROOT_CERT=

# Working directory for a future PROD->Yandex export (later stage; not written
# by anything in this prompt). Git-ignored.
EXPORT_DIR=./.prod-to-yandex-export

# Optional smoke-login credentials for a future auth verify stage. NEVER a real
# production secret committed to git.
MIGRATION_SMOKE_EMAIL=
MIGRATION_SMOKE_PASSWORD=

# Two-key guard (see docs/yandex-migration/05_CUTOVER_RULES.md §4-5).
# Real schema apply requires ALLOW_APPLY_SCHEMA=true AND explicit operator intent.
ALLOW_APPLY_SCHEMA=false

# Destructive Yandex clean is a separate, guarded stage — not used in this prompt.
ALLOW_CLEAN_YANDEX=false
