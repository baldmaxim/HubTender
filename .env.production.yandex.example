# .env.production.yandex.example — production frontend build (Yandex bridge)
# ---------------------------------------------------------------------------
# Назначение: сборка SPA для https://tender.su10.ru так, чтобы ВСЕ бизнес-данные
# шли через Go BFF (→ Yandex PostgreSQL), а Supabase оставался ТОЛЬКО источником
# Auth (login/JWT).
#
# Использование:
#   cp .env.production.yandex.example .env.production
#   # вписать реальный VITE_SUPABASE_PUBLISHABLE_KEY (anon, public-by-design)
#   npm run build            # Vite в mode=production автозагружает .env.production
#
# Почему именно ФАЙЛ .env.production, а НЕ shell-export:
#   isGoEnabled() в src/lib/api/featureFlags.ts читает per-domain флаг через
#   ДИНАМИЧЕСКИЙ import.meta.env[`VITE_API_${DOMAIN}_ENABLED`]. Vite надёжно
#   inline-ит только СТАТИЧЕСКИЕ import.meta.env.VITE_X. Значения, заданные лишь
#   через shell (export / set -a; . file), в динамический доступ прод-бандла не
#   попадают -> isGoEnabled() даёт false -> хелперы валятся в Supabase-fallback.
#   Реальный .env-файл Vite кладёт и в динамический объект import.meta.env.
#
# Только VITE_-переменные уходят в браузерный бандл. НИКОГДА не клади сюда
# секреты (service_role, JWT signing key, пароль БД). anon-ключ публичен по
# дизайну. Файл .env.production — gitignored, не коммитить.

# --- Supabase: ТОЛЬКО Auth (bridge). URL публичен; ключ - anon/publishable ---
VITE_SUPABASE_URL=https://ocauafggjrqvopxjihas.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon / publishable key from Supabase Dashboard>

# --- Маршрутизация: принудительно Go BFF для всех доменов ---
# API_MODE=go -> fallback в isGoEnabled() = (API_MODE === 'go') = true,
# даже если динамический per-domain lookup не разрешится.
VITE_API_MODE=go
# Same-origin: фронт на https://tender.su10.ru -> /api/... -> nginx -> Go BFF.
VITE_API_URL=https://tender.su10.ru

# Realtime через Go BFF WS-хаб (wss://tender.su10.ru/api/v1/ws)
VITE_API_REALTIME_ENABLED=true

# Per-domain Go-флаги. ОБЯЗАТЕЛЬНЫ здесь (в .env-файле), чтобы Vite разрешил
# динамический import.meta.env[...] в isGoEnabled(). Все = true -> бизнес-данные
# идут в Go BFF, не в Supabase PostgREST.
VITE_API_REFERENCES_ENABLED=true
VITE_API_TENDERS_ENABLED=true
VITE_API_POSITIONS_ENABLED=true
VITE_API_BOQ_ENABLED=true
VITE_API_TIMELINE_ENABLED=true
VITE_API_USERS_ENABLED=true
VITE_API_REDISTRIBUTIONS_ENABLED=true
VITE_API_INSURANCE_ENABLED=true
VITE_API_POSITIONFILTERS_ENABLED=true
VITE_API_NOTIFICATIONS_ENABLED=true
VITE_API_TENDERREGISTRY_ENABLED=true
VITE_API_COSTS_ENABLED=true
VITE_API_NOMENCLATURES_ENABLED=true
VITE_API_IMPORTLOG_ENABLED=true
VITE_API_PROJECTS_ENABLED=true
VITE_API_USERADMIN_ENABLED=true
VITE_API_MARKUP_ENABLED=true
VITE_API_FI_ENABLED=true
