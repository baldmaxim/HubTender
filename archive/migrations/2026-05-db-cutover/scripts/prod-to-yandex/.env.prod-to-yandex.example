# scripts/prod-to-yandex/.env.prod-to-yandex.example
#
# Copy to scripts/prod-to-yandex/.env.prod-to-yandex and fill from
# Lockbox / Vault / secret manager. The real file is git-ignored — NEVER commit
# DSNs, passwords, or certificates.
#
# Source of truth for the Yandex stage = PROD Supabase ONLY.
# OLD_SUPABASE_DB_URL is intentionally absent and MUST NOT be added here — the
# scripts fail fast (exit 7) if it is present in the environment.
#
# Connectivity note: on Supabase free-tier the direct host
# db.<ref>.supabase.co is IPv6-only and usually unreachable. If the export /
# check times out, set PROD_SUPABASE_EXPORT_DB_URL to the Session Pooler
# endpoint (aws-0-<region>.pooler.supabase.com:5432). Export & verify prefer
# PROD_SUPABASE_EXPORT_DB_URL over PROD_SUPABASE_DB_URL when it is set.

# PROD Supabase (ocauafggjrqvopxjihas) — the ONLY valid migration source.
PROD_SUPABASE_DB_URL=

# Optional pooler/session-mode override used by export & verify (preferred
# when set). Use this when the direct PROD host times out (IPv6-only).
PROD_SUPABASE_EXPORT_DB_URL=

# Yandex Managed PostgreSQL — migration target (main endpoint; may be pooler).
YANDEX_DATABASE_URL=

# Yandex direct / session-safe endpoint (needed for LISTEN/NOTIFY at the final
# runtime cutover; a transaction-pooler endpoint breaks `rowchange`).
YANDEX_DIRECT_DATABASE_URL=

# Path to the Yandex root CA (.pem) for sslmode=verify-full. If empty, the
# scripts fall back to the sslrootcert= query param inside the DSN.
YANDEX_SSL_ROOT_CERT=

# Working directory for the PROD->Yandex export NDJSON + manifest. Git-ignored.
EXPORT_DIR=./.prod-to-yandex-export

# Optional bcrypt smoke (local; Yandex has no GoTrue). Verifies the migrated
# bcrypt hash against a known plaintext. NEVER a real production secret in git.
MIGRATION_SMOKE_EMAIL=
MIGRATION_SMOKE_PASSWORD=

# ---- Two-key destructive / write guards (see 05_CUTOVER_RULES.md) ----
# Each guard PERMITS but does not ACTIVATE; the matching CLI flag activates.
ALLOW_CLEAN_YANDEX=false
ALLOW_AUTH_IMPORT=false
ALLOW_DATA_IMPORT=false
ALLOW_DISABLE_IMPORT_TRIGGERS=false
