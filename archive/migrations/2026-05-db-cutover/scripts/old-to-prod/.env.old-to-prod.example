# scripts/old-to-prod — env template for OLD Supabase → PROD Supabase migration.
# Copy to .env.old-to-prod (gitignored) and fill values. Never commit secrets.
#
# All variables here are SERVER-ONLY. Never prefix with VITE_ — those leak into
# the browser bundle.

# -----------------------------------------------------------------------------
# Direct PostgreSQL connection strings (Session Pooler endpoint, port 5432).
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# OLD  = legacy live-prod Supabase project (read-only source of truth for cutover).
# PROD = new Supabase project running the Go BFF architecture (target).
# -----------------------------------------------------------------------------
OLD_SUPABASE_DB_URL=
PROD_SUPABASE_DB_URL=

# Optional override for export (`04_export_old.mjs`) only. If set, export
# uses THIS connection string instead of OLD_SUPABASE_DB_URL. Intended for:
#   - feeding `pg_dump`-style long reads through a direct connection that
#     does NOT share pool slots with live frontend traffic;
#   - using a separate Supabase database user dedicated to export with its
#     own statement_timeout / role privileges.
# Pool-safe export mode (`--pool-safe-export`) reads this var first; the
# URL itself is never printed — only its redacted host type (`direct` /
# `pooler` / `unknown`).
OLD_SUPABASE_EXPORT_DB_URL=

# -----------------------------------------------------------------------------
# Supabase REST URLs + keys. anon keys are public by design but we still don't
# log them. service_role keys NEVER appear in logs — used only by future server
# tooling, not by scripts in this folder.
# -----------------------------------------------------------------------------
OLD_SUPABASE_URL=
PROD_SUPABASE_URL=
OLD_SUPABASE_ANON_KEY=
PROD_SUPABASE_ANON_KEY=
OLD_SUPABASE_SERVICE_ROLE_KEY=
PROD_SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Go BFF base URL for post-migration smoke tests. Production-grade:
# e.g. https://api.hubtender.example.com. For local dev: http://localhost:3005.
# -----------------------------------------------------------------------------
GO_BFF_BASE_URL=

# -----------------------------------------------------------------------------
# Smoke account: a real user from OLD whose login + Go BFF /api/v1/me we
# verify on PROD after import. Pick a low-privilege account; never use
# admin/director credentials here.
# -----------------------------------------------------------------------------
MIGRATION_SMOKE_EMAIL=
MIGRATION_SMOKE_PASSWORD=

# Optional read-only tender/position for endpoint smoke tests.
MIGRATION_TEST_TENDER_ID=
MIGRATION_TEST_POSITION_ID=

# Where introspection/export/state scripts write artifacts. Folder is gitignored.
EXPORT_DIR=./.old-to-prod-export

# -----------------------------------------------------------------------------
# Safety flags. Every flag is a two-key lock (CLI flag + this env var) for any
# destructive operation. Defaults are all-safe.
# -----------------------------------------------------------------------------

# Allow scripts to TRUNCATE/DELETE rows on PROD public schema (only with
# explicit CLI flag --clean-prod --confirm).
ALLOW_CLEAN_PROD=false

# Allow scripts to DELETE rows from PROD auth schema (auth.users, auth.identities,
# auth.sessions, auth.refresh_tokens, and any auth table transitively connected
# via FK). Three-key guard: requires CLI --clean-auth AND ALLOW_CLEAN_AUTH=true
# AND ALLOW_AUTH_IMPORT=true. Additional preflight: auth_collision_analysis.json
# must recommend "clean-prod" or "clean-auth"; public tables that reference
# auth.users force --clean-prod --confirm in the same run.
ALLOW_CLEAN_AUTH=false

# Allow import of auth.users / auth.identities into PROD.
ALLOW_AUTH_IMPORT=false

# Allow temporary DISABLE TRIGGER on specific public-schema triggers during
# import (trigger_auto_create_tender_registry, trg_boq_items_audit, etc.).
# Triggers are always re-enabled in a finally block.
ALLOW_DISABLE_IMPORT_TRIGGERS=false

# Allow UPDATE of existing PROD rows (default policy = ON CONFLICT DO NOTHING).
ALLOW_PROD_OVERWRITE=false

# Allow write-smoke-tests (POST/PATCH) on PROD via Go BFF after import.
ALLOW_WRITE_SMOKE_TESTS=false

# Emergency rehearsal safety: allow the importer to silently de-duplicate
# input NDJSON rows that share the same primary key (LIMIT/OFFSET pagination
# drift on a live OLD can produce duplicates). When this is `true` AND CLI
# flag `--allow-import-dedup-for-rehearsal` is passed, the import continues
# and VERIFY status is downgraded to VERIFY_OK_WITH_WARNINGS. Default `false`
# makes any in-import dedup a hard FAIL — which is the right behaviour for
# production cutover. Use only during rehearsal on a frozen-enough OLD where
# the dedup'd rows are demonstrably benign duplicates.
ALLOW_IMPORT_DEDUP_FOR_REHEARSAL=false

# If true, force email_confirmed_at = now() on imported users. Default — copy
# OLD value as-is. Use only if PROD Auth requires confirmed email for login.
FORCE_CONFIRM_EMAILS=false

# -----------------------------------------------------------------------------
# Auth providers that PROD Supabase Dashboard has enabled. Comma-separated.
# Used by 05_prepare_prod to verify OLD identities can authenticate on PROD.
# -----------------------------------------------------------------------------
PROD_ENABLED_AUTH_PROVIDERS=email
