# scripts/yandex-preflight/.env.yandex-preflight.example
#
# Скопировать в scripts/yandex-preflight/.env.yandex-preflight и заполнить
# значениями от оператора Yandex-кластера. Реальный .env.yandex-preflight
# git-ignored (см. .gitignore) — НЕ коммитить его.
#
# Этот preflight ТОЛЬКО читает target (read-only) и НЕ импортирует данные,
# НЕ создаёт таблицы/триггеры, НЕ включает расширения.
#
# Только placeholders — реальные DSN/пароли/сертификаты хранить в Lockbox/Vault.

# Основной DSN Yandex Managed PostgreSQL (target). Рекомендуется sslmode=verify-full.
# Формат: postgresql://<migrator>:<password>@<FQDN>:<port>/<db>?sslmode=verify-full
YANDEX_DATABASE_URL=

# Прямое (session-safe) подключение для проверки LISTEN/NOTIFY (если отдельный endpoint).
# Если пусто — LISTEN проверяется на YANDEX_DATABASE_URL (может быть pooler → warning).
YANDEX_DIRECT_DATABASE_URL=

# DSN пулера (если отдельный endpoint). Transaction-pooler НЕ использовать для LISTEN/NOTIFY.
YANDEX_POOLER_DATABASE_URL=

# Путь к Yandex root CA (.pem/.crt) для sslmode=verify-full. Файл должен существовать.
# Если пусто — берётся sslrootcert= из DSN (YANDEX_DATABASE_URL).
YANDEX_SSL_ROOT_CERT=

# Ожидаемая мажорная версия PostgreSQL (должна совпадать с PROD Supabase).
YANDEX_EXPECTED_PG_MAJOR=17

# Ожидаемое имя БД (сверяется с current_database()). Пусто = проверку пропустить.
YANDEX_EXPECTED_DATABASE=

# Ожидаемый миграционный пользователь (сверяется с current_user). Пусто = пропустить.
YANDEX_EXPECTED_MIGRATOR_USER=

# Ожидаемый runtime-пользователь Go BFF (для справки в отчёте). Пусто = пропустить.
YANDEX_EXPECTED_RUNTIME_USER=
