# TenderHUB — environment variables template.
# Copy to .env or .env.local and fill in real values. Both are gitignored.
#
# ⚠️  SECURITY RULE:
#   Vite exposes every variable prefixed with VITE_ to the client bundle.
#   NEVER prefix a secret (service_role key, JWT signing key, DB password, etc.)
#   with VITE_. Such secrets must stay server-side only (dev scripts, Go backend).

# -----------------------------------------------------------------------------
# Client-safe (bundled into the browser)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon / publishable key from Supabase Dashboard>

# Routing mode: supabase | go | hybrid. `hybrid` honours per-domain flags below.
VITE_API_MODE=hybrid

# Required when any VITE_API_*_ENABLED=true. In production this MUST be set.
VITE_API_URL=http://localhost:3005

# Per-domain Go BFF flags. `true` → route via Go endpoints; absent/false → Supabase.
# Domains marked READY have working Go endpoints in backend/internal/handlers/.
# Domains marked PENDING still rely on direct Supabase calls in src/pages/.
VITE_API_REFERENCES_ENABLED=true
VITE_API_TENDERS_ENABLED=true
VITE_API_POSITIONS_ENABLED=true
VITE_API_BOQ_ENABLED=true
VITE_API_TIMELINE_ENABLED=true
VITE_API_USERS_ENABLED=true
VITE_API_REDISTRIBUTIONS_ENABLED=true
VITE_API_INSURANCE_ENABLED=true
VITE_API_POSITIONFILTERS_ENABLED=true
VITE_API_NOTIFICATIONS_ENABLED=true
VITE_API_TENDERREGISTRY_ENABLED=true
VITE_API_COSTS_ENABLED=true
VITE_API_NOMENCLATURES_ENABLED=true
VITE_API_IMPORTLOG_ENABLED=true
VITE_API_PROJECTS_ENABLED=true
VITE_API_USERADMIN_ENABLED=true
VITE_API_MARKUP_ENABLED=true
VITE_API_FI_ENABLED=true
# Note: страница /Commerce работает через комбинацию доменов выше
# (tenders + positions + boq + markup + insurance) — отдельного Go-домена нет.

# Realtime: WebSocket hub on Go BFF (Postgres LISTEN/NOTIFY → broker → WS).
VITE_API_REALTIME_ENABLED=true

# Sentry (frontend error tracking). DSN публичен по дизайну (rate-limited
# Sentry SDK key). Без DSN init — no-op, Sentry не активируется.
# VITE_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=hubtender@1.0.0   # хеш коммита из CI

# -----------------------------------------------------------------------------
# Server-only (dev scripts in scripts/ and the Go backend).
# Never load these via import.meta.env. Never add a VITE_ prefix.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=<service_role / secret key from Supabase Dashboard — rotate if leaked>

# Go BFF (phase 2+)
#
# Supabase free tier: the direct hostname `db.<ref>.supabase.co` is IPv6-only.
# From IPv4 environments (Docker Desktop on Windows, most CI runners) the
# Session Pooler must be used instead:
#
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Grab the exact URL at Dashboard → Settings → Database → Connection string →
# Session pooler (port 5432, supports prepared statements).
# Transaction pooler (port 6543) is NOT compatible with pgx defaults.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
REDIS_URL=redis://localhost:6379

# JWT verification for Go backend. Choose ONE depending on Supabase project setup:
# - HS256 (symmetric, default for older projects): set SUPABASE_JWT_SECRET.
# - RS256 (asymmetric, JWKS): set SUPABASE_JWKS_URL.
SUPABASE_JWT_SECRET=<JWT secret from Supabase Dashboard → Settings → JWT>
SUPABASE_JWKS_URL=https://ocauafggjrqvopxjihas.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://ocauafggjrqvopxjihas.supabase.co/auth/v1

# Caddy reverse-proxy (docker-compose)
API_HOST=api.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# Go BFF tuning (все опциональные, дефолты подходят для prod)
# BIND_HOST=0.0.0.0           # на каком интерфейсе слушать (по умолчанию все)
# DB_MAX_CONNS=20              # верхний лимит pgx-пула
# DB_MIN_CONNS=2               # нижний лимит pgx-пула
# DB_MAX_CONN_IDLE_TIME=5m     # сколько ждать перед закрытием idle-коннекта
