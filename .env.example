# TenderHUB — environment variables template.
# Copy to .env or .env.local and fill in real values. Both are gitignored.
#
# ⚠️  SECURITY RULE:
#   Vite exposes every variable prefixed with VITE_ to the client bundle.
#   NEVER prefix a secret (JWT signing key, DB password, etc.) with VITE_.
#   Such secrets must stay server-side only (dev scripts, Go backend).

# -----------------------------------------------------------------------------
# Client-safe (bundled into the browser)
# -----------------------------------------------------------------------------
# Routing mode: go | hybrid. `hybrid` honours per-domain flags below.
# `go` forces all domains to the Go BFF regardless of per-domain flags.
VITE_API_MODE=hybrid

# Required when any VITE_API_*_ENABLED=true. In production this MUST be set.
VITE_API_URL=http://localhost:3005

# Per-domain Go BFF flags. `true` → route via Go endpoints; absent/false →
# Supabase PostgREST fallback (data-access only, no auth).
VITE_API_REFERENCES_ENABLED=true
VITE_API_TENDERS_ENABLED=true
VITE_API_POSITIONS_ENABLED=true
VITE_API_BOQ_ENABLED=true
VITE_API_TIMELINE_ENABLED=true
VITE_API_USERS_ENABLED=true
VITE_API_REDISTRIBUTIONS_ENABLED=true
VITE_API_INSURANCE_ENABLED=true
VITE_API_POSITIONFILTERS_ENABLED=true
VITE_API_NOTIFICATIONS_ENABLED=true
VITE_API_TENDERREGISTRY_ENABLED=true
VITE_API_COSTS_ENABLED=true
VITE_API_NOMENCLATURES_ENABLED=true
VITE_API_IMPORTLOG_ENABLED=true
VITE_API_PROJECTS_ENABLED=true
VITE_API_USERADMIN_ENABLED=true
VITE_API_MARKUP_ENABLED=true
VITE_API_FI_ENABLED=true
# Note: страница /Commerce работает через комбинацию доменов выше
# (tenders + positions + boq + markup + insurance) — отдельного Go-домена нет.

# Realtime: WebSocket hub on Go BFF (Postgres LISTEN/NOTIFY → broker → WS).
VITE_API_REALTIME_ENABLED=true

# Sentry (frontend error tracking). DSN публичен по дизайну (rate-limited
# Sentry SDK key). Без DSN init — no-op, Sentry не активируется.
# VITE_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=hubtender@1.0.0   # хеш коммита из CI

# -----------------------------------------------------------------------------
# Server-only (Go backend + dev scripts in scripts/).
# Never load these via import.meta.env. Never add a VITE_ prefix.
# -----------------------------------------------------------------------------
# pgx connection string. Production runs against Yandex Managed PostgreSQL.
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=verify-full

# Caddy / nginx reverse-proxy
CORS_ORIGINS=https://yourdomain.com

# --- App-issued JWT (signs access tokens served to the frontend) -------------
APP_JWT_ISSUER=https://api.yourdomain.com
APP_JWT_AUDIENCE=hubtender-web
APP_JWT_KEY_ID=<kid string, exposed in JWKS — pick something opaque>
# Provide either a path or a base64-encoded key body (not both):
APP_JWT_PRIVATE_KEY_PATH=/etc/hubtender/app-jwt.pem
# APP_JWT_PRIVATE_KEY_B64=<base64 of PEM-encoded RSA private key>
APP_ACCESS_TOKEN_TTL_MINUTES=15
APP_REFRESH_TOKEN_TTL_DAYS=30

# Environment ("development" | "staging" | "production"). The /forgot-password
# endpoint refuses to silently drop mail when APP_ENV=production AND no SMTP
# creds are set — returns HTTP 503 email_provider_not_configured instead.
APP_ENV=development

# Public origin used to build password-reset links. Required when SMTP is set.
APP_BASE_URL=https://yourdomain.com

# --- SMTP (password recovery only). Empty SMTP_HOST → NoopMailer ------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="TenderHUB <noreply@yourdomain.com>"

# --- Sentry (backend error tracking). Empty DSN → no-op ---------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=hubtender-api@<git-sha>

# --- Go BFF tuning (опциональные, дефолты подходят для prod) ----------------
# BIND_HOST=0.0.0.0
# PORT=3005
# DB_MAX_CONNS=20
# DB_MIN_CONNS=2
# DB_MAX_CONN_IDLE_TIME=5m
